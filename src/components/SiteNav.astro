---
import { site } from '../events/registry.js';

// items = in-page section anchors (event pages pass their own). Cross-page
// navigation goes only through the library landing, where the gates live.
const { items = [], brand = site.name } = Astro.props;
const anchors = items.filter((item) => item.href.startsWith('#'));
---
<nav class="site-nav" aria-label="Основная навигация">
  <a class="site-nav__brand" href="/" aria-label="На главную">{brand}</a>
  <div class="site-nav__side">
    <div class="site-nav__links">
      {anchors.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </div>
    <a class="site-nav__library" href="/">Библиотека</a>
  </div>
</nav>
