---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import PageHero from '../../components/PageHero.astro';
import LandingLibrary from '../../components/LandingLibrary.astro';
import { libraryEvent, site, sharedGallery } from '../registry.js';

const polaroids = [
  { ...sharedGallery[2], tilt: -7, depth: 22 },
  { ...sharedGallery[4], tilt: 5, depth: 34 },
  { ...sharedGallery[0], tilt: -3, depth: 14 }
];
---
<BaseLayout title={site.title} theme={libraryEvent.theme} preloader={libraryEvent.preloader}>
  <SiteNav />
  <main>
    <PageHero
      eyebrow={libraryEvent.eyebrow}
      title={libraryEvent.title}
      subtitle={libraryEvent.subtitle}
      lead={libraryEvent.lead}
      image={libraryEvent.heroImage}
      imageAlt="Теплый момент из библиотеки"
      align="left"
      imageClass="page-hero__image--home"
    >
      <div class="hero-polaroids" aria-hidden="true" data-parallax>
        {polaroids.map((p, i) => (
          <figure class="hero-polaroid" style={`--tilt: ${p.tilt}deg; --depth: ${p.depth}; --delay: ${i * 1.4}s`}>
            <img src={p.src} alt="" loading="eager" />
            <figcaption>{p.title}</figcaption>
          </figure>
        ))}
      </div>
    </PageHero>
    <LandingLibrary library={libraryEvent} />
  </main>
  <footer class="site-footer">{site.madeFor}</footer>
</BaseLayout>

<style>
  .hero-polaroids {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-polaroid {
    position: absolute;
    margin: 0;
    width: clamp(120px, 11vw, 168px);
    padding: 8px 8px 26px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 4px;
    box-shadow: 0 22px 44px -20px var(--shadow);
    transform: rotate(var(--tilt));
    animation: polaroid-bob 7s ease-in-out var(--delay) infinite alternate;
  }

  .hero-polaroid:nth-child(1) { left: 38%; top: 16%; }
  .hero-polaroid:nth-child(2) { left: 51%; top: 52%; }
  .hero-polaroid:nth-child(3) { left: 33%; top: 62%; }

  .hero-polaroid img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  .hero-polaroid figcaption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 5px;
    color: var(--accent-2);
    font-family: Caveat, cursive;
    font-size: 15px;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @keyframes polaroid-bob {
    from { transform: rotate(var(--tilt)) translateY(-7px); }
    to { transform: rotate(var(--tilt)) translateY(7px); }
  }

  @media (max-width: 980px) {
    .hero-polaroid:nth-child(1),
    .hero-polaroid:nth-child(3) {
      display: none;
    }

    .hero-polaroid:nth-child(2) {
      left: auto;
      right: 6%;
      top: 58%;
    }
  }
</style>

<script>
  const layer = document.querySelector('[data-parallax]');
  const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  const calm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (layer && fine && !calm) {
    const cards = layer.querySelectorAll('.hero-polaroid');
    window.addEventListener('pointermove', (event) => {
      const dx = event.clientX / window.innerWidth - 0.5;
      const dy = event.clientY / window.innerHeight - 0.5;
      cards.forEach((card) => {
        const depth = Number(card.style.getPropertyValue('--depth')) || 20;
        card.style.translate = `${dx * depth}px ${dy * depth}px`;
      });
    }, { passive: true });
  }
</script>
